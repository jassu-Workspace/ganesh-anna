{
  "version": 2,
  "builds": [
    {
      "src": "voyageai-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/voyageai-backend/server.js"
    }
  ]
}
